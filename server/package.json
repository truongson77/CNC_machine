{
  "name": "server",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:usb": "cross-env SERIAL_PORT=auto tsx watch src/index.ts",
    "dev:com12": "cross-env SERIAL_PORT=COM12 SERIAL_BAUD=115200 tsx watch src/index.ts",
    "ports": "tsx src/scripts/listPorts.ts",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@serialport/parser-readline": "^13.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "serialport": "^13.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.1",
    "@types/ws": "^8.5.13",
    "cross-env": "^7.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
